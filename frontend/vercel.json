{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://vybe-backend-93eu.onrender.com/api/sitemap"
    },
    {
      "source": "/products/:id(\\w{24})",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|TelegramBot|Slackbot|Discordbot|Pinterest).*"
        }
      ],
      "destination": "https://vybe-backend-93eu.onrender.com/api/og/product/:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
